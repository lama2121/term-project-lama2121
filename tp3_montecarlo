def onStep(app):
    if app.mode == "showdown":
        handleShowdown(app)
        return
    if app.mode != "play":
        return
    
    currentIndex = app.currentPlayerIndex  
    
    if app.foldedPlayers[currentIndex] or app.lostPlayers[currentIndex] or app.allInPlayers[currentIndex]:
        advanceTurn(app)
        return
    if currentIndex == 3:
        app.waitingForPlayer = True
        return
    
    app.turnTimer += 1
    if app.turnTimer >= 10:
        botAction(app, currentIndex)  
        advanceTurn(app)
        
def handleShowdown(app):
    
    app.showdownTimer += 1
    if app.showdownTimer < 60:
        return
    
    app.showdownTimer = 0
    
    if app.showdownPhase == "preflop":
        dealFlop(app)
        app.showdownPhase = "flop"
    elif app.showdownPhase == "flop":
        dealTurn(app)
        app.showdownPhase = "turn"
    elif app.showdownPhase == "turn":
        dealRiver(app)
        app.showdownPhase = "river"
    elif app.showdownPhase == "river":
        buildSidePots(app)
        distributeSidePots(app)
        app.mode = "showwinners"
        
def updateTotalContributed(app, playerIndex, targetAmount):
    # targetAmount = what the player should have contributed in total this round
    # we only add the difference (top-up) from what they already paid this round
    topUp = targetAmount - app.contributedThisRound[playerIndex]
    if topUp > 0:
        app.totalContributed[playerIndex] += topUp
        app.contributedThisRound[playerIndex] = targetAmount

def buildSidePots(app):
    app.sidePots = []
    
    # If nobody is all-in, there's only one pot — everyone eligible who didn't fold
    if not any(app.allInPlayers[i] for i in range(4) 
               if not app.lostPlayers[i]):
        eligible = [i for i in range(4) 
                    if not app.foldedPlayers[i] and not app.lostPlayers[i]]
        app.sidePots = [{'amount': app.pot, 'eligible': eligible}]
        return

    # Only reach here if someone is actually all-in
    contribs = list(app.totalContributed)

    while True:
        activeLevels = [contribs[i] for i in range(4)
                        if not app.foldedPlayers[i] and not app.lostPlayers[i]
                        and contribs[i] > 0]
        if not activeLevels:
            break

        level = min(activeLevels)
        potAmount = 0
        eligible = []

        for i in range(4):
            if app.lostPlayers[i]:
                continue
            contribution = min(contribs[i], level)
            potAmount += contribution
            contribs[i] -= contribution
            if contribution > 0 and not app.foldedPlayers[i]:
                eligible.append(i)

        if potAmount > 0:
            app.sidePots.append({'amount': potAmount, 'eligible': eligible})

    remainder = sum(contribs[i] for i in range(4) if contribs[i] > 0)
    if remainder > 0 and app.sidePots:
        app.sidePots[-1]['amount'] += remainder
        
    #for checking
    print(app.sidePots)
    

def checkAndFlagAllIn(app, playerIndex):
    # If a call or raise wiped out their stack, treat them as all-in
    if app.playersData[playerIndex]['money'] == 0 and not app.allInPlayers[playerIndex]:
        app.allInPlayers[playerIndex] = True
        app.lastActions[playerIndex] = app.lastActions[playerIndex] + " (All-In)"



def monteCarloWinProb(app, botIndex, numSimulations=150):


    #known cards for the player
    botHand   = app.playerCards[botIndex]   # the bot's 2 hole cards
    community = app.communityCards[:]       # community cards dealt so far (0–5)

    
    # A bot can only see its own hand + the community cards, nothing else!
    usedCards = set(botHand + community)
    drawPile  = [card for card in createDeck() if card not in usedCards]


    opponents = [
        i for i in range(4)
        if i != botIndex
        and not app.foldedPlayers[i]
        and not app.lostPlayers[i]
    ]

    if not opponents:
        return 1.0          # bot is the last player standing just for carefulness

    # How many community cards still need to be revealed
    communityCardsMissing = 5 - len(community)

    #runsimulationsss
    totalScore = 0.0

    for _ in range(numSimulations):

        # Shuffle a fresh copy of the draw pile for this simulation
        simDeck = drawPile[:]
        random.shuffle(simDeck)
        drawIndex = 0

        # 1.Fill in the missing community cards
        simCommunity = community + simDeck[drawIndex : drawIndex + communityCardsMissing]
        drawIndex += communityCardsMissing

        # 2.Give each opponent 2 random hole cards
        oppHands = {}
        for opp in opponents:
            oppHands[opp] = simDeck[drawIndex : drawIndex + 2]
            drawIndex += 2

        # 3.Score the bot's best hand (its 2 hole cards + 5 community cards)
        botHandName, botScore = getRankOfCombination(botHand + simCommunity)
        botKey = makeScoreKey(botScore[0], botScore[1])

        # 4.Score every opponent and find the strongest one
        oppKeys = []
        for opp in opponents:
            oppName, oppScore = getRankOfCombination(oppHands[opp] + simCommunity)
            oppKeys.append(makeScoreKey(oppScore[0], oppScore[1]))

        bestOppKey = max(oppKeys)

        # 5.Compare and award points
        if botKey > bestOppKey:
            totalScore += 1.0   # clear win

        elif botKey == bestOppKey:
            tiedPlayers = 1 + oppKeys.count(bestOppKey)
            totalScore += 1.0 / tiedPlayers   #— partial credit

        # loss → add nothing

    #probability
    return totalScore / numSimulations



