def getBotThresholds(personality):
    if personality == 'aggressive':
        raiseCutoff = 0.40   # raises with mediocre hands
        callCutoff  = 0.20   # almost never folds
        bluffChance = 0.20   # 20% chance to bluff regardless of probability
        maxRaise    = 80     # willing to raise big amounts
    else:  # normal
        raiseCutoff = 0.65   # only raises with strong hands
        callCutoff  = 0.40   # folds when hand is weak
        bluffChance = 0.05   # rarely bluffs
        maxRaise    = 50     # raises moderate amounts

    # small random nudge to avoid predictability — same nudge for both so their gap never changes
    nudge        = random.uniform(-0.05, 0.05)
    raiseCutoff += nudge
    callCutoff  += nudge

    return raiseCutoff, callCutoff, bluffChance, maxRaise


def botAction(app, playerIndex):
    if app.lostPlayers[playerIndex]:
        return

    
    # personality is either 'aggressive' or 'normal'
    # raiseCutoff : winProb needed to raise
    # callCutoff  : winProb needed to call (below this → fold)
    # bluffChance :  probability of faking a strong hand
    # maxRaise    : biggest raise amount this bot will do
    personality = app.botPersonalities[playerIndex]
    raiseCutoff, callCutoff, bluffChance, maxRaise = getBotThresholds(personality)

   
    simCounts = {'preflop': 75, 'flop': 100, 'turn': 125, 'river': 150}
    winProb = monteCarloWinProb(app, playerIndex, simCounts[app.phase])

    # preflop boost: Monte Carlo underestimates hole card strength when no community cards are known yet
    # so we nudge winProb up to avoid everyone folding preflop
    if app.phase == 'preflop':
        winProb += 0.15

    # if bluffing, pretend winProb is high so the bot acts confident
    # aggressive bots bluff more (higher bluffChance from getBotThresholds)
    isBluffing = random.random() < bluffChance
    if isBluffing:
        winProb = random.uniform(0.7, 1.0)

   
    canCheck = not app.hasBetThisRound


    if canCheck and winProb < callCutoff and app.phase != 'preflop':
        # weak hand + no bet yet : just check, no point folding for free
        app.lastActions[playerIndex] = "Check"
        app.playersActedSinceRaise.add(playerIndex)

    elif winProb > raiseCutoff:
        # strong hand : try to raise
        raiseAmount = random.randrange(app.minBet, maxRaise + 1, 10)
        totalBet = app.callAmount + raiseAmount

        if totalBet <= app.playersData[playerIndex]['money']:
            # can afford the raise : do it
            topUp = totalBet - app.contributedThisRound[playerIndex]
            app.pot += topUp
            app.amountsBetThisRound[playerIndex] = totalBet
            app.playersData[playerIndex]['money'] -= topUp
            app.callAmount = totalBet
            app.lastActions[playerIndex] = f"Raise +${raiseAmount}"
            checkAndFlagAllIn(app, playerIndex)
            app.hasBetThisRound = True
            app.playersActedSinceRaise = {playerIndex}
            app.lastRaiserIndex = playerIndex
            updateTotalContributed(app, playerIndex, totalBet)

        elif app.callAmount <= app.playersData[playerIndex]['money']:
            # can't raise but can call : call instead
            topUp = app.callAmount - app.contributedThisRound[playerIndex]
            app.pot += topUp
            app.playersData[playerIndex]['money'] -= topUp
            checkAndFlagAllIn(app, playerIndex)
            app.amountsBetThisRound[playerIndex] = app.callAmount
            app.lastActions[playerIndex] = f"Call ${app.callAmount}"
            app.hasBetThisRound = True
            app.playersActedSinceRaise.add(playerIndex)
            updateTotalContributed(app, playerIndex, app.callAmount)

        else:
            # can't even call : all-in or fold based on prob + personality
            # aggressive: min 60% all-in chance, normal: min 20%
            if personality == 'aggressive':
                allInChance = 0.60 + winProb * 0.40
            else:
                allInChance = 0.20 + winProb * 0.40

            if random.random() < allInChance:
                amount = app.playersData[playerIndex]['money']
                if amount > 0:
                    app.pot += amount
                    app.playersData[playerIndex]['money'] = 0
                    app.allInPlayers[playerIndex] = True
                    app.lastActions[playerIndex] = f"All-In ${amount}"
                    app.hasBetThisRound = True
                    target = app.contributedThisRound[playerIndex] + amount
                    app.amountsBetThisRound[playerIndex] = target
                    updateTotalContributed(app, playerIndex, target)
                    if amount > app.callAmount:
                        app.callAmount = amount
                        app.playersActedSinceRaise = {playerIndex}
                        app.lastRaiserIndex = playerIndex
                    else:
                        app.playersActedSinceRaise.add(playerIndex)
            else:
                app.foldedPlayers[playerIndex] = True
                app.lastActions[playerIndex] = "Fold"
                app.amountsBetThisRound[playerIndex] = 'f'

    elif winProb > callCutoff:
        # medium hand → try to call
        if app.callAmount <= app.playersData[playerIndex]['money']:
            # can afford to call : do it
            topUp = app.callAmount - app.contributedThisRound[playerIndex]
            app.pot += topUp
            app.playersData[playerIndex]['money'] -= topUp
            app.lastActions[playerIndex] = f"Call ${app.callAmount}"
            checkAndFlagAllIn(app, playerIndex)
            updateTotalContributed(app, playerIndex, app.callAmount)
            app.hasBetThisRound = True
            app.amountsBetThisRound[playerIndex] = app.callAmount
            app.playersActedSinceRaise.add(playerIndex)

        else:
            # can't afford to call : all-in or fold based on prob + personality
            # aggressive: min 60% all-in chance, normal: min 20%
            if personality == 'aggressive':
                allInChance = 0.60 + winProb * 0.40
            else:
                allInChance = 0.20 + winProb * 0.40

            if random.random() < allInChance:
                amount = app.playersData[playerIndex]['money']
                if amount > 0:
                    app.pot += amount
                    app.playersData[playerIndex]['money'] = 0
                    app.allInPlayers[playerIndex] = True
                    app.lastActions[playerIndex] = f"All-In ${amount}"
                    app.hasBetThisRound = True
                    target = app.contributedThisRound[playerIndex] + amount
                    app.amountsBetThisRound[playerIndex] = target
                    updateTotalContributed(app, playerIndex, target)
                    if amount > app.callAmount:
                        app.callAmount = amount
                        app.playersActedSinceRaise = {playerIndex}
                        app.lastRaiserIndex = playerIndex
                    else:
                        app.playersActedSinceRaise.add(playerIndex)
            else:
                app.foldedPlayers[playerIndex] = True
                app.lastActions[playerIndex] = "Fold"
                app.amountsBetThisRound[playerIndex] = 'f'

    else:
        # weak hand : fold
        app.foldedPlayers[playerIndex] = True
        app.lastActions[playerIndex] = "Fold"
        app.playersActedSinceRaise.add(playerIndex)
        app.amountsBetThisRound[playerIndex] = 'f'
        
def roundIsOver(app):
    # Round ends when every active player has acted since the last raise
    # AND all non-folded bets are equal
    for i in range(4):
        if (not app.foldedPlayers[i] and not app.lostPlayers[i] and
            not app.allInPlayers[i]):
            if i not in app.playersActedSinceRaise:
                return False  # someone still needs to act

    #Now we check all active bets are equal
    amounts = [app.amountsBetThisRound[i] for i in range(4)
               if not app.foldedPlayers[i] and not app.lostPlayers[i] and not app.allInPlayers[i]]
    if not amounts:  # everyone remaining is all-in — round is genuinely over
        return True
    
    return len(set(amounts)) <= 1

def advanceTurn(app):
    #Advance to next player or next phase
    # Counting active players
    activePlayers = 0
    for i in range(len(app.foldedPlayers)):
        if not app.foldedPlayers[i] and not app.lostPlayers[i]:
            activePlayers += 1
    #If only one player left, end game #to be modified
            
    playersMoney = [app.playersData[i]['money'] for i in range(len(app.playersData))]
            
    if activePlayers <= 1 and playersMoney.count(0) == 3:
        app.mode = "gameover"
        return
    
    elif activePlayers <= 1:
        app.mode = "luckywin"
        # find the only player who didn't fold
        for i in range(len(app.foldedPlayers)):
            if not app.foldedPlayers[i]:
                winnerIndex = i
                break
    
    # give them the entire pot
        app.playersData[winnerIndex]['money'] += app.pot
    
    # store winner for display
        app.winnerIndexes = [winnerIndex]
        app.winningCombo = "All others folded"
    
        app.pot = 0
        app.mode = "luckywin"
        return 
    
    #Checking if all active players have acted this round
    activePlayers = 0
    for i in range(4):
        if not app.foldedPlayers[i] and not app.lostPlayers[i]:
            activePlayers += 1

    if roundIsOver(app):
        # Check if we should go straight to showdown instead of normal phase
        if isShowdown(app):
            startShowdown(app)
        else:
            advancePhase(app)
        return
        
    #Moving on to next player
    app.currentPlayerIndex = (app.currentPlayerIndex + 1) % 4
    app.turnTimer = 0
    app.waitingForPlayer = False
    
    
def distributeSidePots(app):
    app.winnerIndexes = []
    app.winningCombo = ""
    
    # Iterate smallest pot first (they were built smallest-first in buildSidePots)
    for pot in app.sidePots:
        amount = pot['amount']
        eligible = pot['eligible']
        
        if not eligible:
            continue
        
        # Build a temporary foldedPlayers mask so getWinners only considers
        # eligible players for THIS pot — everyone else is treated as folded
        tempFolded = [True, True, True, True]
        for i in eligible:
            tempFolded[i] = False
        
        bestName, winners = getWinners(app, app.playerCards, 
                                        app.communityCards, tempFolded)
        
        # Split the pot evenly among winners of this pot
        share = amount // len(winners)
        remainder = amount % len(winners)  # handle odd chips
        
        for i in winners:
            app.playersData[i]['money'] += share
            # Add any leftover chip to the first winner
        app.playersData[winners[0]]['money'] += remainder
        
        # Track all winners across all pots for display
        for i in winners:
            if i not in app.winnerIndexes:
                app.winnerIndexes.append(i)
        
        # Keep the winning combo of the LAST (biggest) pot for display
        # since that's the most contested one
        app.winningCombo = bestName
    
    app.pot = 0

def advancePhase(app):
    #Move to next phase of the game
    if app.phase == "preflop":
        app.phase = "flop"
        dealFlop(app)
    elif app.phase == "flop":
        app.phase = "turn" 
        dealTurn(app)
    elif app.phase == "turn":
        app.phase = "river"
        dealRiver(app)
    elif app.phase == "river":
        buildSidePots(app)
        app.mode = "showwinners"
        distributeSidePots(app)
        return
    
    # Reset for new betting round
    app.playersActedSinceRaise = set()
    app.lastRaiserIndex = app.currentPlayerIndex
    app.currentPlayerIndex = 0
    app.turnTimer = 0
    app.waitingForPlayer = False
    app.hasBetThisRound = False # Reset betting flag
    app.callAmount = app.minBet # Reset call amount to minimum
    app.contributedThisRound = [0, 0, 0, 0]  # resets each phase, NOT each hand

    
    # Clear last actions
    for i in range(4):
        if not app.foldedPlayers[i]:
            app.lastActions[i] = ""

#Community card dealing functions based on the game phase:
def dealFlop(app):
    # needs 3 cards 
    for i in range(3):
        card = app.deck.pop()
        app.communityCards.append(card)

def dealTurn(app):
    # deals only one card 
    card = app.deck.pop()
    app.communityCards.append(card)

def dealRiver(app):
    # deals final card
    card = app.deck.pop()
    app.communityCards.append(card)

