# Player action handlers
def handlePlayerCall(app):
    #Handle player CALL action
    if app.callAmount <= app.playersData[3]['money']:
        topUp = app.callAmount - app.contributedThisRound[3]  # only the difference
        app.pot += topUp
        app.playersData[3]['money'] -= topUp
        app.lastActions[3] = f"Call ${app.callAmount}"
        checkAndFlagAllIn(app, 3)
        app.hasBetThisRound = True
        app.playersActedSinceRaise.add(3)
        app.amountsBetThisRound[3] = app.callAmount
        updateTotalContributed(app, 3, app.callAmount)
        return True
    return False

def handlePlayerCheck(app):
    #Handle player CHECK action
    if not app.hasBetThisRound:  # Only allow check if no one has bet
        app.lastActions[3] = "Check"
        app.playersActedSinceRaise.add(3)
        return True
    return False

def handlePlayerRaise(app):
    #Handle player RAISE action
    totalBet = app.callAmount + app.raiseAmount
    if totalBet <= app.playersData[3]['money']:
        topUp = totalBet - app.contributedThisRound[3]  # only the difference
        app.pot += topUp
        app.amountsBetThisRound[3] = totalBet
        app.playersData[3]['money'] -= topUp
        app.lastActions[3] = f"Raise +${app.raiseAmount}"
        checkAndFlagAllIn(app, 3)
        app.callAmount = totalBet  # Update call amount for other players
        app.hasBetThisRound = True
        app.playersActedSinceRaise = {3}
        app.lastRaiserIndex = 3
        updateTotalContributed(app, 3, totalBet)
        return True
    return False

def handlePlayerAllIn(app):
    amount = app.playersData[3]['money']
    if amount <= 0:
        return False # already broke, nothing to do
    app.pot += amount
    # total contributed this round = what they already paid + this remaining amount
    target = app.contributedThisRound[3] + amount
    app.amountsBetThisRound[3] = target
    updateTotalContributed(app, 3, target)
    app.playersData[3]['money'] = 0
    app.allInPlayers[3] = True
    app.lastActions[3] = f"All-In ${amount}"
    app.hasBetThisRound = True

    if amount > app.callAmount:
        # going all-in for MORE than the current call so its treated like a raise
        app.callAmount = amount
        app.playersActedSinceRaise = {3}
        app.lastRaiserIndex = 3
    else:
        # going all-in for LESS than or equal to the call so its just a partial call
        app.playersActedSinceRaise.add(3)
    return True

def handlePlayerFold(app):
    #Handle player FOLD action
    app.foldedPlayers[3] = True
    app.lastActions[3] = "Fold"
    app.playersActedSinceRaise.add(3)   
    app.amountsBetThisRound[3] = 'f'
    return True

def onMousePress(app, mouseX, mouseY):
    if (app.mode != "play" or app.currentPlayerIndex != 3 or
        app.foldedPlayers[3]):
        return

    coords = getButtonCoordinates(app)

    if isPlusButtonClicked(mouseX, mouseY, coords):
        handlePlusClick(app)
    elif isMinusButtonClicked(mouseX, mouseY, coords):
        handleMinusClick(app)
    elif isCallButtonClicked(mouseX, mouseY, coords):
        if handlePlayerCall(app):
            advanceTurn(app)
    elif isCheckButtonClicked(mouseX, mouseY, coords) and not app.hasBetThisRound:
        if handlePlayerCheck(app):
            advanceTurn(app)
    elif isRaiseButtonClicked(mouseX, mouseY, coords):
        if handlePlayerRaise(app):
            advanceTurn(app)
    elif isFoldButtonClicked(mouseX, mouseY, coords):
        if handlePlayerFold(app):
            advanceTurn(app)
    elif isAllInButtonClicked(mouseX, mouseY, coords) and not app.allInPlayers[3]:  
        if handlePlayerAllIn(app):
            advanceTurn(app)

