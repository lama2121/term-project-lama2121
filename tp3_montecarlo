def isShowdown(app):
    # Showdown occurs when at most one non-folded, non-lost player is NOT all-in
    # meaning no more betting can happen
    activePlayers = [i for i in range(4) 
                     if not app.foldedPlayers[i] and not app.lostPlayers[i]]
    nonAllIn = [i for i in activePlayers if not app.allInPlayers[i]]
    if len(nonAllIn) > 1:
        return False
    
    # If exactly one non-all-in player remains, they must have already acted
    # (called/folded) before we trigger showdown — otherwise they haven't
    # had a chance to respond to the all-in yet
    if len(nonAllIn) == 1:
        lastPlayer = nonAllIn[0]
        return lastPlayer in app.playersActedSinceRaise
    
    # Zero non-all-in players — everyone is all-in, showdown immediately
    return True


