        app.botPersonalities = ['aggressive', 'aggressive', 'aggressive', None]
    elif app.gameMode == 'normal':
        app.botPersonalities = ['normal', 'normal', 'normal', None]
    elif app.gameMode == 'mixed':
        app.botPersonalities = ['aggressive', 'normal', 'normal', None]
